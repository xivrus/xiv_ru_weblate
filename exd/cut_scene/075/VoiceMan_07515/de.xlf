      <trans-unit id="2" xml:space="preserve" approved="yes">
        <source>2</source>
        <target state="final">TEXT_VOICEMAN_07515_000020_CEFCA&lt;tab&gt;(-Kefka-)Ich werde alles zerstören und eine Welt des Todes schaffen!</target>
      </trans-unit>
      <trans-unit id="3" xml:space="preserve" approved="yes">
        <source>3</source>
        <target state="final">TEXT_VOICEMAN_07515_000030_CEFCA&lt;tab&gt;(-Kefka-)Nghaaaa! Was fällt euch ein, mich so in Bedrängnis zu bringen?</target>
      </trans-unit>
