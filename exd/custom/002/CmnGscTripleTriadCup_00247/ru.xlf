        <source>5</source>
        <target state="translated">TEXT_CMNGSCTRIPLETRIADCUP_00247_A1_000_002&lt;tab&gt;Посмотреть текущие места в турнире.</target>
      </trans-unit>
      <trans-unit id="6" xml:space="preserve" approved="no">
        <source>6</source>
        <target state="translated">TEXT_CMNGSCTRIPLETRIADCUP_00247_A1_000_006&lt;tab&gt;Спросить о местах в турнире.</target>
      </trans-unit>
