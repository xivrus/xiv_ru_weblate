        <source>7</source>
        <target state="translated">TEXT_CMNGSCTRIPLETRIADCUP_00247_A1_000_003&lt;tab&gt;Спросить о наградах турнира.</target>
      </trans-unit>
      <trans-unit id="8" xml:space="preserve" approved="no">
        <source>8</source>
        <target state="translated">TEXT_CMNGSCTRIPLETRIADCUP_00247_A1_000_004&lt;tab&gt;Спросить о правилах турнира.</target>
